  },
  "devDependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.0.0"
  }
}
